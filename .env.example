# Copy this file to .env and fill in your own RealWorld test-account credentials.
#
# How to create a test account:
#   1. Open https://demo.realworld.show/#/register
#   2. Register with any username, e-mail, and password
#   3. Enter those values below
#
TEST_USER_EMAIL=your@email.com
TEST_USER_PASSWORD=yourpassword
# Must match the username chosen during registration (shown in the nav after login)
TEST_USER_USERNAME=yourusername
